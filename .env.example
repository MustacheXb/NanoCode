# LLM Provider Configuration
# Available providers: claude, openai, custom
LLM_PROVIDER=claude

# Claude API Configuration
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Custom API endpoint for Claude
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Default Claude model
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI API Configuration
OPENAI_API_KEY=sk-...
# Optional: Custom API endpoint (for Azure, local LLM, etc.)
# OPENAI_BASE_URL=https://api.openai.com
# Default OpenAI model
# OPENAI_MODEL=gpt-4o

# Custom LLM Configuration (for OpenAI-compatible APIs)
# CUSTOM_API_KEY=your-api-key
# CUSTOM_BASE_URL=https://your-api-endpoint.com
# CUSTOM_MODEL=your-model-name

# Common LLM Settings
NANOAGENT_MAX_TOKENS=8192
NANOAGENT_TEMPERATURE=0

# Search API Configuration (for web search)
# NANOAGENT_SEARCH_ENGINE=duckduckgo

# Permission Level
# Options: bypass, accept, ask, plan
# NANOAGENT_PERMISSION_LEVEL=ask

# Sandbox Settings
# NANOAGENT_SANDBOX_ENABLED=true
# NANOAGENT_SANDBOX_TIMEOUT_MS=30000

# Compression Settings
# NANOAGENT_MAX_CONTEXT_TOKENS=200000
# NANOAGENT_MEMORY_STRATEGY=lru

# Database Settings
# NANOAGENT_DB_PATH=.nanoagent/nanoagent.db
# NANOAGENT_SESSION_TTL_MS=604800000
